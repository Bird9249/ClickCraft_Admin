# Runtime env บนเซิร์ฟเวอร์ — คัดลอกไปที่ /etc/clickcraft-admin.env
# sudo cp deploy/templates/env.example /etc/clickcraft-admin.env
# แล้วแก้ค่าจริง + chmod 600

NODE_ENV=production
PORT=3005

DATABASE_URL=postgres://clickcraft:CHANGE_ME@localhost:5432/clickcraft

BETTER_AUTH_SECRET=CHANGE_ME_long_random_secret
BETTER_AUTH_BASE_URL=https://admin.clickcraft.dev

# Admin UI + Website (public quotation leads)
CORS_ORIGIN=https://admin.clickcraft.dev,https://clickcraft.dev

# S3/MinIO object store (presigned upload) — ใส่เมื่อพร้อมใช้
# S3_ENDPOINT=https://s3.example.com
# S3_BUCKET=clickcraft
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
